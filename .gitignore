# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/tests/e2e/.auth/
/playwright-report/
/test-results/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/dev-server.log

# env files (can opt-in for committing if needed)
.env
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts debug/inspección de raíz (desarrollo, no producción)
/inspect-*.js
/run-*.js
/seed-*.js
/test-e2e.js
/check-*.js
/read-excel*.js
/generate-icon.js
/reset-passwords.js
/deploy-copyright.txt

# playwright MCP (snapshots y logs de esta sesión)
/.playwright-mcp/

# screenshots raíz (capturas manuales, no parte del repo)
/*.png

# Expo / React Native build artifacts
apps/mobile/android/app/src/main/assets/
apps/mobile/android/app/src/main/res/drawable-hdpi/
apps/mobile/android/app/src/main/res/drawable-mdpi/
apps/mobile/android/app/src/main/res/drawable-xhdpi/
apps/mobile/android/app/src/main/res/drawable-xxhdpi/
apps/mobile/android/app/src/main/res/drawable-xxxhdpi/

