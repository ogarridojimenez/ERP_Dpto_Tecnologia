# ============================================================================
# SITRADE — Variables de entorno (ejemplo)
# ============================================================================
# Copia este archivo como .env.local y completa los valores.
# NUNCA commitees el .env.local ni pegues credenciales reales aquí.

# --- Supabase (producción) ---
# Encuentra estos valores en Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Base de datos directa SUPABASE (para migraciones/Prisma) ---
# Encuentra la contraseña en Supabase Dashboard → Settings → Database
# Formato pooler (puerto 6543) recomendado para serverless/edge
DATABASE_URL="postgresql://postgres.your-project-ref:your-db-password@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Formato directo (puerto 5432) para migraciones de Prisma
DIRECT_URL="postgresql://postgres.your-project-ref:your-db-password@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# --- Base de datos LOCAL (desarrollo sin internet) ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sitrade"

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
