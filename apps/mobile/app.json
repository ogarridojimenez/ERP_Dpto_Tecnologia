{
  "expo": {
    "name": "AFT Mobile",
    "slug": "aft-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "aftmobile",
    "splash": {
      "backgroundColor": "#1e3a5f"
    },
    "ios": {
      "bundleIdentifier": "com.sitrade.aft",
      "supportsTablet": true
    },
    "android": {
      "package": "com.sitrade.aft",
      "adaptiveIcon": {
        "backgroundColor": "#1e3a5f"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a la cámara para escanear códigos QR de activos."
        }
      ]
    ]
  }
}
